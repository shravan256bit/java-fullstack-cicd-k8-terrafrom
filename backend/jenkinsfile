pipeline {
    agent any

    tools {
        jdk 'jdk-17'
        maven 'Maven-3.9'
    }

    environment {
        IMAGE_NAME = "shravan256bit/auth-backend"
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('checkout code') {
            steps {
                git branch: 'main',
                url: "https://github.com/shravan256bit/java-fullstack-cicd-k8-terrafrom.git"
            }
        }
        stage('Build - Maven') {
            steps {
                dir('backend/auth') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('backend/auth') {
                    withSonarQubeEnv('sonarqube-server') {
                        sh 'mvn sonar:sonar -Dsonar.projectKey=auth-backend'
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend/auth') {
                    sh 'docker build -t $IMAGE_NAME:$IMAGE_TAG .'
                }
            }
        }
        stage('trivy scan'){
            steps{
                sh """ 
                trivy image --exit-code 1 --severity HIGH,CRITICAL $IMAGE_NAME:$IMAGE_TAG
                """
            }
        }
        stage('push to hub'){
            steps{
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cri',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh """
                        docker login -u $DOCKER_USER -p $DOCKER_PASS
                        docker push $IMAGE_NAME:$IMAGE_TAG
                        """
                    }
            }
        }
        stage('Update Helm Values') {
            steps {
                withCredentials([string(credentialsId: 'git-token', variable: 'GIT_TOKEN')]) {
                    sh '''
                        cd helm-charts
                        git config user.email "shravanoncloud6@gmail.com"
                        git config user.name "shravan256bit"
                        yq -i ".backend.image.tag = \\"$IMAGE_TAG\\"" values.yaml
                        git add values.yaml
                        git commit -m "Update backend image to $IMAGE_TAG"
                        git remote set-url origin https://$GIT_TOKEN@github.com/shravan256bit/java-fullstack-cicd-k8-terrafrom.git
                        git push origin main
                    '''
                }
            }
        }
    }
}