pipeline {
    agent any

    environment {
        IMAGE_NAME = "shravan256bit/auth-frontend"
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                url: "https://github.com/shravan256bit/java-fullstack-cicd-k8-terrafrom.git"
            }
        }

        stage('Build Docker Image') {
            when {
                anyOf {
                    changeset "frontend/**"
                    changeset "helm-charts/**"
                }
            }
            steps {
                dir('frontend') {
                    sh 'docker build -t $IMAGE_NAME:$IMAGE_TAG .'
                }
            }
        }


        stage('Push to DockerHub') {
            when {
                anyOf {
                    changeset "frontend/**"
                    changeset "helm-charts/**"
                }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cri',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    docker login -u $DOCKER_USER -p $DOCKER_PASS
                    docker push $IMAGE_NAME:$IMAGE_TAG
                    '''
                }
            }
        }

        stage('Update Helm Values') {
            when {
                changeset "frontend/**"
            }
            steps {
                withCredentials([string(credentialsId: 'git-token', variable: 'GIT_TOKEN')]) {
                    sh '''
                        cd helm-charts
                        git config user.email "shravanoncloud6@gmail.com"
                        git config user.name "shravan256bit"
                        yq -i ".frontend.image.tag = \\"$IMAGE_TAG\\"" values.yaml
                        git add values.yaml
                        git commit -m "Update frontend image to $IMAGE_TAG"
                        git remote set-url origin https://$GIT_TOKEN@github.com/shravan256bit/java-fullstack-cicd-k8-terrafrom.git
                        git pull origin main --rebase
                        git push origin main
                    '''
                }
            }
        }
    }
}